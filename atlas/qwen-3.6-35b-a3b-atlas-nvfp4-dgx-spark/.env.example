# .env.example - Template for Atlas auth token and model config
# This is just a template file. DO NOT edit this file directly.
# The docker compose requires that you create a proper .env file.
# The .env file is not committed to the repository to protect sensitive credentials.
# Copy this template to .env and set your actual values.
#
# Atlas uses --auth-token (single bearer token). Generate one with:
#   openssl rand -hex 24

ATLAS_API_KEY=dummy-key
ATLAS_MODEL=RedHatAI/Qwen3.6-35B-A3B-NVFP4
