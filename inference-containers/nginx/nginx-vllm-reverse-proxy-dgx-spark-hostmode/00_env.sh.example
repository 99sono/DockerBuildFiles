# .env.sh.example - Template file for nginx reverse proxy bash scripts
# Do NOT edit this file directly.
# Copy to 00_env.sh and replace the placeholder values with your actual configuration.
#
# This file is for bash scripts (04_test_curl.sh, etc.), NOT docker-compose.
# Docker-compose uses .env files; bash scripts use .sh env files.

# ============================================================
# vLLM API KEY
# ============================================================
# Set your vLLM API key. If you don't require authentication,
# you can keep the default `dummy-key`.
#
# This key is used in the Authorization header:
#   Authorization: Bearer $VLLM_API_KEY
VLLM_API_KEY=dummy-key

# ============================================================
# DGX HOSTNAME
# ============================================================
# Set the hostname of the DGX server that vLLM is running on.
# This is used to construct URLs for testing.
DGX_HOSTNAME=localhost

# ============================================================
# SSL IP ADDRESS
# ============================================================
# IP address to include in the certificate SAN extension.
# This ensures browser trust compatibility (Chrome 58+).
# Set this to your local network IP (e.g., 192.168.1.55)
SSL_IP_ADDRESS=127.0.0.1

# ============================================================
# CONTAINER NAMES
# ============================================================
# Docker container and project names used by the scripts.
# These should match the docker-compose.yml configuration.
#
# NGINX_CONTAINER_NAME: The explicit container_name in docker-compose.yml
# PROJECT_NAME: Used with --project-name flag for docker compose commands
NGINX_CONTAINER_NAME=nginx-proxy-hostmode
PROJECT_NAME=vllm-https-hostmode