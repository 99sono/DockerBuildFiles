# .env.example - Template file for nginx reverse proxy configuration
# Do NOT edit this file directly.
# Copy to .env and replace the placeholder values with your actual configuration.

# ============================================================
# DGX SPARK IP ADDRESS
# ============================================================
# Replace the dummy value below with your DGX Spark's actual
# static IP address (e.g. 192.168.1.50, 10.0.0.50, etc.)
#
# Example: DGX_IP=192.168.1.50
#
# IMPORTANT: The certificate generation script will refuse to
# run if this is still the dummy placeholder [DGX_IP]. You
# MUST replace it with your real DGX IP before running any
# setup scripts.
DGX_IP=[DGX_IP]

# ============================================================
# vLLM API KEY
# ============================================================
# Set your vLLM API key. If you don't require authentication,
# you can keep the default `dummy-key`.
VLLM_API_KEY=dummy-key
