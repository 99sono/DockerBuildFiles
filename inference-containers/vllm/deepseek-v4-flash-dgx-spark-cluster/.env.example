# =============================================================================
# DeepSeek-V4-Flash Dual DGX Spark Cluster — Environment Configuration
# =============================================================================
# Copy this file to .env and edit for your network.
#   cp .env.example .env
# =============================================================================

# ---- General ----
INFERENCE_API_KEY="dummy-key"
INFERENCE_MODEL_ALIAS="deepseek-v4-flash"

# ---- Cluster topology ----
# MASTER_ADDR = IP of the head node for GLOO TCP rendezvous.
# GLOO is the bootstrap protocol vLLM uses for initial handshake
# (finding the master, exchanging addresses). It only speaks TCP,
# not RDMA. This must be reachable from the worker node.
MASTER_ADDR="10.0.1.1"           # spark01 Port 1 IP (head node)

# ---- NCCL / RDMA (dual-port RoCE) ----
# Both ConnectX-7 ports are used for GPU↔GPU data (activations,
# gradients). NCCL automatically stripes across all listed HCAs,
# giving ~400 Gb/s aggregate bandwidth.

NCCL_IB_DISABLE="0"              # 0 = enable RDMA; 1 = force TCP fallback

# RoCE HCAs for NCCL. Each port gets its own HCA name.
# Listing both enables dual-port bandwidth aggregation.
NCCL_IB_HCA="rocep1s0f0,roceP2p1s0f0"

# Which GID (Global ID) index carries the assigned IPv4 on each HCA.
# Verify with: for i in 0..7; do cat /sys/class/infiniband/<hca>/ports/1/gids/$i; done
# Look for a GID containing "ffff:0a00:xxxx" — that index goes here.
# Must match the correct index for both ports.
NCCL_IB_GID_INDEX="4,4"

# NCCL_SOCKET_IFNAME = TCP fallback interface for NCCL.
# When RDMA is unavailable (e.g. control messages), NCCL falls back to
# regular TCP over this NIC. Use the management ethernet, not RoCE.
NCCL_SOCKET_IFNAME="enP7s7"

# GLOO_SOCKET_IFNAME = bootstrap / rendezvous interface.
# GLOO coordinates initial handshake between nodes (finding master,
# exchanging addresses). It only speaks TCP. Binding to the management
# NIC prevents it from accidentally picking a RoCE interface.
GLOO_SOCKET_IFNAME="enP7s7"

# TP_SOCKET_IFNAME = Tensor Parallel coordination interface.
# Similar purpose to GLOO — keep on the management NIC.
TP_SOCKET_IFNAME="enP7s7"

# Prevents NCCL from warning about CPU affinity mismatches (common in
# containers — the pinned CPU set may not match GPU affinities).
NCCL_IGNORE_CPU_AFFINITY="1"

NCCL_DEBUG="WARN"                # Log level: WARN (prod) | INFO | TRACE

# ---- CUDA compilation targets (GB10 = SM121) ----
TORCH_CUDA_ARCH_LIST="12.1a"
FLASHINFER_CUDA_ARCH_LIST="12.1a"

# ---- vLLM tuning ----
VLLM_ALLOW_LONG_MAX_MODEL_LEN="1"
VLLM_USE_B12X_MOE="1"
VLLM_SPARSE_INDEXER_MAX_LOGITS_MB="256"
