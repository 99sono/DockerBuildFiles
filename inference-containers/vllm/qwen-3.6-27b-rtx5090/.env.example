# =============================================================================
# .env.example — vLLM inference server config (Qwen 3.6-27B, RTX 5090)
# Copy to .env and edit. The .env file is gitignored.
# All variables use INFERENCE_ prefix (framework-agnostic).
# docker-compose.yml uses ${VAR:-default} syntax, so a .env is optional.
# =============================================================================

# API key for server authentication (--api-key flag)
INFERENCE_API_KEY=dummy-key

# Model alias exposed in /v1/models API (--served-model-name flag)
INFERENCE_MODEL_ALIAS=qwen3.6-27b-text

# Port mapping host:container (internal container port always 8000)
INFERENCE_SERVER_PORT=8000

# Client-facing URL for test scripts
INFERENCE_SERVER_URL=http://localhost:8000/v1
