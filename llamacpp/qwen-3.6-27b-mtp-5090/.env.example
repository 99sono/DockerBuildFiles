# =============================================================================
# .env.example
# Environment variables for llama.cpp Qwen 3.6-27B MTP server
# =============================================================================

# API key for the llama-server (optional - uncomment to enable)
# LLAMA_SERVER_KEY=your-secret-api-key

# Server URL for testing scripts
LLAMA_SERVER_URL=http://localhost:8081

# Container name
LLAMA_CONTAINER_NAME=qwen-3.6-27b-mtp-5090

# Port mapping (host:container)
LLAMA_SERVER_PORT=8081