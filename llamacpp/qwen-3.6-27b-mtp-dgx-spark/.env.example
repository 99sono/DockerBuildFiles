# =============================================================================
# .env.example
# Environment variables for llama.cpp Qwen 3.6-27B MTP server (DGX Spark)
# =============================================================================

# API key for the llama-server (used by --api-key and client requests)
LLAMA_API_KEY=dummy-key

# Server URL for testing scripts
LLAMA_SERVER_URL=http://localhost:8081

# Container name
LLAMA_CONTAINER_NAME=qwen-3.6-27b-mtp-dgx-spark

# Port mapping (host:container)
LLAMA_SERVER_PORT=8081
