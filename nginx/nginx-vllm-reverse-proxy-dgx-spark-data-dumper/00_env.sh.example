# .env.sh.example - Template file for debug proxy bash scripts
# Do NOT edit this file directly.
# Copy to 00_env.sh and replace the placeholder values with your actual configuration.

# ============================================================
# DEBUG PROXY CONFIGURATION
# ============================================================
# Port for the debug proxy (HTTP only, no SSL)
DEBUG_PROXY_PORT=8888

# Container name for the debug proxy
DEBUG_CONTAINER_NAME=nginx-proxy-debug

# Docker compose project name
COMPOSE_PROJECT_NAME=nginx-debug

# Directory for debug log files
DEBUG_LOGS_DIR="./debug_logs"

# vLLM backend hostname (same as production)
VLLM_BACKEND=vllm
VLLM_BACKEND_PORT=8000